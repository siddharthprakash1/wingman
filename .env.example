# Wingman AI Assistant - Environment Configuration
# Copy this file to .env and fill in your actual API keys
#
# Quick Start:
# 1. cp .env.example .env
# 2. Fill in at least one LLM provider key (OpenAI recommended)
# 3. Run: python -m src.main onboard

# =============================================================================
# WORKSPACE CONFIGURATION (Security & Sandboxing)
# =============================================================================

# Workspace directory for all agent operations (files, shell commands)
# Default: ~/.wingman/workspace
WINGMAN_WORKSPACE=~/.wingman/workspace

# Enable workspace sandboxing (strongly recommended)
WINGMAN_WORKSPACE_SANDBOXED=true

# =============================================================================
# LLM PROVIDERS (at least one required)
# =============================================================================

# --- OpenAI ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1

# --- Groq (OpenAI-compatible, very fast) ---
# https://console.groq.com/keys
GROQ_API_KEY=

# --- Kimi (Moonshot K2.5) ---
# https://platform.moonshot.cn
KIMI_API_KEY=

# --- Google Gemini ---
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GOOGLE_API_KEY=
LANGEXTRACT_API_KEY=

# --- OpenRouter (multi-model proxy) ---
# https://openrouter.ai
OPENROUTER_API_KEY=

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=

# --- Ollama (local, no key) ---
OLLAMA_API_BASE=http://localhost:11434

# =============================================================================
# OVERNIGHT "NIGHT LAB" SWARM
# =============================================================================

# Which provider the overnight pipeline uses (openai / groq / kimi / gemini)
OVERNIGHT_PROVIDER=openai

# Model name for the overnight pipeline. Default = cheap + capable.
OVERNIGHT_MODEL=gpt-4o-mini

# Minutes between cycles (default 60)
OVERNIGHT_CYCLE_MINUTES=60

# =============================================================================
# MESSAGING CHANNELS (optional)
# =============================================================================

TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# =============================================================================
# VOICE (optional)
# =============================================================================

PICOVOICE_ACCESS_KEY=
ELEVENLABS_API_KEY=

# =============================================================================
# APPLICATION DEFAULTS
# =============================================================================

# Format: provider/model-name   (e.g. openai/gpt-4o-mini, groq/llama-3.3-70b-versatile)
DEFAULT_MODEL=openai/gpt-4o-mini
WORKSPACE_PATH=~/.wingman/workspace
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=18789
LOG_LEVEL=INFO
MAX_TOKENS=4000
TEMPERATURE=0.7
MAX_TOOL_ITERATIONS=25
SESSION_TIMEOUT=3600

# =============================================================================
# EMBEDDINGS / RAG
# =============================================================================

# Options: all-MiniLM-L6-v2 (fast), all-mpnet-base-v2 (better quality)
EMBEDDINGS_MODEL=all-MiniLM-L6-v2

# =============================================================================
# SECURITY
# =============================================================================

ALLOW_SHELL_COMMANDS=true
ALLOW_FILESYSTEM_ACCESS=true

# 1. NEVER commit .env with real keys
# 2. Rotate keys regularly
# 3. Separate keys for dev/prod
